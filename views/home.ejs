<!DOCTYPE html>
<html>
<head>
  <title>Stayzio - Home</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css" />

</head>
<body>

  <%- include('partials/navbar') %>

  <div class="container mt-4">
    <h1>All Listings</h1>
    <div class="row">
      <% listings.forEach(listing => { %>
      <div class="col-md-4 d-flex align-items-stretch mb-4">

  <div class="card mb-4 shadow-sm h-100 listing-card">
    <img src="<%= listing.image %>" class="card-img-top listing-img" alt="Listing Image">
    <div class="card-body d-flex flex-column">
      <h5 class="card-title"><%= listing.title %></h5>
      <p class="card-text flex-grow-1"><%= listing.description %></p>

      <div class="mt-auto">
        <a href="/book/<%= listing._id %>" class="btn btn-primary">Book Now</a>
        <% if (currentUser && currentUser.role === 'admin') { %>
          <a href="/admin/listings/<%= listing._id %>/edit" class="btn btn-warning ms-2">Edit</a>
          <form action="/admin/listings/<%= listing._id %>?_method=DELETE" method="POST" class="d-inline ms-2">
            <button class="btn btn-danger">Delete</button>
          </form>
        <% } %>
      </div>
    </div>
  </div>
</div>

      <% }) %>
    </div>
  </div>

  
<%- include('partials/footer') %>

</body>
</html>
