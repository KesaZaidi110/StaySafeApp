<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-light bg-light fixed-top shadow-sm px-4 py-2">

  <a class="navbar-brand" href="/">Stayzio</a>
  <div class="ms-auto">
    <% if (!currentUser) { %>
      <a href="/signin" class="btn btn-outline-primary me-2">Sign In</a>
      <a href="/signup" class="btn btn-primary">Sign Up</a>
    <% } else { %>
      <% if (currentUser.role === 'admin') { %>
        <a href="/admin" class="btn btn-outline-warning me-2">Admin Panel</a>
      <% } else { %>
        <a href="/user/dashboard" class="btn btn-outline-success me-2">My Dashboard</a>
      <% } %>
      <a href="/logout" class="btn btn-danger">Logout</a>
    <% } %>
    <button id="theme-toggle" class="btn btn-secondary ms-2">🌓</button>
  </div>
</nav>

</body>
</html>